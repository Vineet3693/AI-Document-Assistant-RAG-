# DocuMind AI - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ============================================
# API KEYS
# ============================================

# OpenAI API Key (required for GPT-4, GPT-3.5, embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional, for Claude models)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Pinecone API Key (optional, for production vector DB)
# Get from: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=documind-ai

# ============================================
# DATABASE
# ============================================

# MongoDB URI (optional, for user data and analytics)
# Format: mongodb://username:password@host:port/database
MONGODB_URI=mongodb://localhost:27017/documind_ai

# ============================================
# SECURITY
# ============================================

# Secret key for JWT token signing and session management
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_key_change_this_in_production

# Encryption key for document encryption (AES-256)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_encryption_key_here

# ============================================
# APPLICATION SETTINGS
# ============================================

# Environment: development, staging, production
APP_ENV=development

# Application host and port
APP_HOST=0.0.0.0
APP_PORT=8000

# Enable debug mode (disable in production)
DEBUG=true

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8501

# ============================================
# DOCUMENT STORAGE
# ============================================

# Directory for uploaded documents
UPLOAD_DIR=./data/uploads

# Directory for vector store (if using ChromaDB locally)
VECTORSTORE_DIR=./data/vectorstore

# Directory for exported files
EXPORT_DIR=./data/exports

# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# ============================================
# RATE LIMITING
# ============================================

# Requests per minute per user
RATE_LIMIT_PER_MINUTE=60

# Questions per day per user
QUESTIONS_PER_DAY=1000

# Uploads per day per user
UPLOADS_PER_DAY=100

# ============================================
# MONITORING & ANALYTICS
# ============================================

# Enable cost tracking
ENABLE_COST_TRACKING=true

# Alert threshold in USD (daily)
COST_ALERT_THRESHOLD_USD=100

# Enable audit logging
ENABLE_AUDIT_LOGGING=true

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable specific features
ENABLE_OCR=true
ENABLE_TABLE_EXTRACTION=true
ENABLE_TRANSLATION=true
ENABLE_MULTI_DOCUMENT_QA=true
ENABLE_EXPORT_PDF=true
ENABLE_EXPORT_WORD=true
ENABLE_EXPORT_EXCEL=true

# Industry modes
ENABLE_LEGAL_MODE=true
ENABLE_FINANCE_MODE=true
ENABLE_HEALTHCARE_MODE=true
ENABLE_HR_MODE=true
ENABLE_RESEARCH_MODE=true
ENABLE_EDUCATION_MODE=true

# ============================================
# COMPLIANCE
# ============================================

# GDPR compliance mode (EU users)
GDPR_MODE=false

# HIPAA compliance mode (healthcare)
HIPAA_MODE=false

# Auto-delete documents after N days (0 = never)
AUTO_DELETE_DAYS=90

# ============================================
# LOGGING
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory
LOG_DIR=./logs
